{
  "openapi": "3.0.3",
  "info": {
    "title": "Skin Advisor",
    "description": "Skin analysis results and retailer click events from the Beauty Concierge skin advisor.",
    "version": "1.0.0"
  },
  "paths": {},
  "components": {
    "schemas": {
      "Skin_Analysis": {
        "type": "object",
        "required": ["email", "analysis_date", "overall_score", "skin_age", "skin_type"],
        "properties": {
          "email":            { "type": "string",  "description": "User email — primary identity key" },
          "crm_contact_id":   { "type": "string",  "description": "Salesforce Contact ID (optional, populated when user is known in CRM)" },
          "analysis_date":    { "type": "string",  "format": "date-time", "description": "ISO 8601 timestamp of the analysis" },
          "overall_score":    { "type": "integer", "description": "Overall skin health score 0–100" },
          "skin_age":         { "type": "integer", "description": "Estimated skin age" },
          "skin_type":        { "type": "string",  "description": "dry | oily | combination | normal | sensitive" },
          "primary_concern":  { "type": "string",  "description": "Top skin concern label" },
          "source":           { "type": "string",  "description": "Origin of the analysis, e.g. web_skin_advisor" },

          "acne_score":           { "type": "integer" },
          "acne_severity":        { "type": "string"  },
          "wrinkle_score":        { "type": "integer" },
          "wrinkle_severity":     { "type": "string"  },
          "dark_circle_score":    { "type": "integer" },
          "dark_circle_severity": { "type": "string"  },
          "eye_bag_score":        { "type": "integer" },
          "eye_bag_severity":     { "type": "string"  },
          "pore_score":           { "type": "integer" },
          "pore_severity":        { "type": "string"  },
          "spot_score":           { "type": "integer" },
          "spot_severity":        { "type": "string"  },
          "redness_score":        { "type": "integer" },
          "redness_severity":     { "type": "string"  },
          "texture_score":        { "type": "integer" },
          "texture_severity":     { "type": "string"  },
          "oiliness_score":       { "type": "integer" },
          "oiliness_severity":    { "type": "string"  },
          "hydration_score":      { "type": "integer" },
          "hydration_severity":   { "type": "string"  },
          "firmness_score":       { "type": "integer" },
          "firmness_severity":    { "type": "string"  },
          "radiance_score":       { "type": "integer" },
          "radiance_severity":    { "type": "string"  },
          "sensitivity_score":    { "type": "integer" },
          "sensitivity_severity": { "type": "string"  },
          "uv_damage_score":      { "type": "integer" },
          "uv_damage_severity":   { "type": "string"  },
          "uneven_tone_score":    { "type": "integer" },
          "uneven_tone_severity": { "type": "string"  }
        }
      },

      "Retailer_Click": {
        "type": "object",
        "required": ["email", "clicked_at", "retailer_name", "product_id", "product_name"],
        "properties": {
          "email":          { "type": "string",  "description": "User email — primary identity key" },
          "crm_contact_id": { "type": "string",  "description": "Salesforce Contact ID (optional)" },
          "clicked_at":     { "type": "string",  "format": "date-time", "description": "ISO 8601 timestamp of the click" },
          "retailer_name":  { "type": "string",  "description": "e.g. Target, Amazon, Sephora" },
          "retailer_url":   { "type": "string"  },
          "is_online":      { "type": "boolean" },
          "is_in_store":    { "type": "boolean" },
          "product_id":     { "type": "string"  },
          "product_name":   { "type": "string"  },
          "product_brand":  { "type": "string"  },
          "product_price":  { "type": "number"  },
          "source":         { "type": "string"  }
        }
      }
    }
  }
}
